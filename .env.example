# Chimera Configuration
# Copy this file to .env and fill in the required values.
# Lines beginning with # are comments. Uncomment to override a default.

# ── Chimera Chat Server ───────────────────────────────────────────────────────

# Port the Chimera HTTP server listens on
# CHIMERA_PORT=3210

# Bind address — keep 127.0.0.1 (localhost only). Changing this exposes the
# server on your network. Chimera has no authentication.
# CHIMERA_HOST=127.0.0.1

# Max milliseconds a run_command call may run before timing out
# CHIMERA_CMD_TIMEOUT=60000

# Comma-separated list of directories the AI is allowed to read/write/run in.
# Defaults to Desktop, Documents, Downloads under the current user's home dir.
# ALLOWED_DIRS=/home/youruser/Desktop,/home/youruser/Documents

# ── Ollama ────────────────────────────────────────────────────────────────────

# Ollama host and port (default: local, port 11434)
# LM_HOST=127.0.0.1
# LM_PORT=11434

# Chat model — must be pulled with: ollama pull <model>
# LM_MODEL=qwen3:8b

# ── RAG (embedded — no Docker required) ──────────────────────────────────────

# Embedding model — must be pulled with: ollama pull nomic-embed-text
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_EMBED_DIM=768

# Path to the embedded SQLite RAG database file
# RAG_DB=./chimera-rag.db

# RAG server listen port (used internally by chimera-rag.js)
# RAG_PORT=8080
# RAG_HOST=127.0.0.1

# ── MCP Gateway ──────────────────────────────────────────────────────────────

# RAG server URL as seen by the MCP gateway process
# RAG_SERVER_URL=http://localhost:8080

# HTTP request timeout for MCP tool calls (ms)
# REQUEST_TIMEOUT=30000
